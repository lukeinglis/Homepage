---
import Layout from "../layouts/Layout.astro";
import { getDayConfig, getGreeting, getTimeOfDay } from "../config/loader";
import { WidgetWrapper } from "../components/WidgetWrapper";
import { ClockWidget } from "../components/ClockWidget";
import { QuickLinksWidget } from "../components/QuickLinksWidget";

const config = getDayConfig();
const greeting = getGreeting();
const timeOfDay = getTimeOfDay();
---

<Layout>
  <header class="header">
    <h1 class="greeting">{greeting}</h1>
    <p class="focus-text">{config.focusText}</p>
  </header>

  <main>
    <section class="widget-grid">
      <WidgetWrapper name="clock" client:load>
        <ClockWidget />
      </WidgetWrapper>

      <WidgetWrapper name="quickLinks" client:load>
        <QuickLinksWidget links={config.quickLinks} />
      </WidgetWrapper>

      {
        config.widgets
          .filter((w) => w.id !== "clock" && w.id !== "quickLinks")
          .map((widget) => (
            <div class="widget-placeholder" data-widget={widget.id}>
              {widget.id}
            </div>
          ))
      }
    </section>
  </main>
</Layout>

<style>
  .header {
    text-align: center;
    padding: 2rem 0;
  }

  .greeting {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-primary);
    margin-bottom: 0.5rem;
  }

  @media (min-width: 768px) {
    .greeting {
      font-size: 2rem;
    }
  }

  .focus-text {
    font-size: 1rem;
    color: var(--color-secondary);
    max-width: 600px;
    margin: 0 auto;
  }

  @media (min-width: 768px) {
    .focus-text {
      font-size: 1.125rem;
    }
  }

  main {
    padding-top: 1rem;
  }
</style>
